# AssemblyAI – preferred audio transcription provider (supports speaker labels, timed segments)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# OpenAI Whisper – fallback transcription provider when AssemblyAI is not configured
# At least one of ASSEMBLYAI_API_KEY or OPENAI_API_KEY is required for audio hook analysis.
# Without either key, the audio agent will run on ffmpeg waveform heuristics only (reduced quality).
OPENAI_API_KEY=your_openai_api_key_here

# Gemini Vision - required for frame-by-frame visual analysis
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here
